{
  "name": "@promptframe/component-kit",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./standard": {
      "import": "./dist/standard.js",
      "types": "./dist/standard.d.ts"
    },
    "./preview": {
      "import": "./dist/preview.js",
      "types": "./dist/preview.d.ts"
    },
    "./timing": {
      "import": "./dist/timing.js",
      "types": "./dist/timing.d.ts"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ty-teams/promptframe-component-kit.git",
    "directory": "packages/component-kit"
  },
  "bugs": {
    "url": "https://github.com/ty-teams/promptframe-component-kit/issues"
  },
  "homepage": "https://github.com/ty-teams/promptframe-component-kit#readme",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "remotion": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
