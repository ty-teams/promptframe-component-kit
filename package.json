{
  "name": "promptframe-component-kit-release",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm --filter @promptframe/component-kit build",
    "lint": "pnpm --filter @promptframe/component-kit lint",
    "test": "pnpm --filter @promptframe/component-kit test",
    "pack:dry-run": "pnpm --filter @promptframe/component-kit build && npm pack --dry-run --json --workspace @promptframe/component-kit"
  }
}
